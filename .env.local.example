# ── AI Models ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth → console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth → github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (magic link emails) → resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ── Bot protection ────────────────────────────────────────────────────────────
# Cloudflare Turnstile → dash.cloudflare.com → Application security → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Turso (libSQL) → turso.tech → create DB → get URL + token
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Any strong random string
ADMIN_SECRET=

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_ID=price_...
